# 네이버 개발자센터에서 발급: https://developers.naver.com/apps/#/register
# 사용 API: 검색 (지역, 블로그, 카페글)
NAVER_CLIENT_ID=your_client_id_here
NAVER_CLIENT_SECRET=your_client_secret_here

# 공공데이터포털 API 서비스키 (임산부/육아 혜택 조회)
# https://www.data.go.kr 에서 발급
DATA_GO_KR_SERVICE_KEY=your_service_key_here

# 어필리에이트 트래킹 ID (기본: mamma)
# NEXT_PUBLIC_AFFILIATE_ID=mamma

# 앱 기본 URL (선택)
# NEXT_PUBLIC_BASE_URL=https://mamma.app

# 위치 기반 맛집 정렬 활성화 (기본: true)
# NEXT_PUBLIC_ENABLE_GEOLOCATION=true

# 자동 백업 알림 간격 (일 단위, 0=비활성, 기본: 7)
# NEXT_PUBLIC_AUTO_BACKUP_DAYS=7

# 클라우드 동기화 (향후 Firebase/Supabase 연동)
# NEXT_PUBLIC_CLOUD_SYNC=false
# NEXT_PUBLIC_CLOUD_SYNC_ENDPOINT=

# 푸시 알림 (향후 PWA Push Notification)
# NEXT_PUBLIC_PUSH_ENABLED=false
# NEXT_PUBLIC_VAPID_KEY=
